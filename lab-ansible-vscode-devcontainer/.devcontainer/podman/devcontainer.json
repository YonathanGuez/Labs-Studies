{
  "name": "Ansible Lab",
  "image": "ghcr.io/ansible/community-ansible-dev-tools:latest",
  "customizations": {
    "vscode": {
      "extensions": ["redhat.ansible", "ms-python.python"],
      "settings": {
        "ansible.executionEnvironment.enabled": true,
        "ansible.executionEnvironment.containerEngine": "docker",
        "ansible.path": "/usr/bin/ansible",
        "ansibleNavigator.path": "/usr/local/bin/ansible-navigator"
      }
    }
  },
  "mounts": [
    "source=${localEnv:XDG_RUNTIME_DIR}/podman/podman.sock,target=${localEnv:XDG_RUNTIME_DIR}/podman/podman.sock,type=bind"
  ],
  "remoteUser": "root"
}
